{
  "name": "WidgetSettings",
  "type": "object",
  "properties": {
    "primary_color": {
      "type": "string",
      "default": "#3b82f6"
    },
    "widget_position": {
      "type": "string",
      "enum": [
        "bottom-right",
        "bottom-left"
      ],
      "default": "bottom-right"
    },
    "greeting_message": {
      "type": "string"
    },
    "chatbot_name": {
      "type": "string",
      "default": "ShopBot"
    },
    "chatbot_avatar_url": {
      "type": "string"
    },
    "show_branding": {
      "type": "boolean",
      "default": true
    },
    "prechat_form_enabled": {
      "type": "boolean",
      "default": false
    },
    "prechat_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "offline_message": {
      "type": "string"
    },
    "custom_css": {
      "type": "string"
    },
    "privacy_policy_url": {
      "type": "string",
      "description": "Privacy policy URL for login dialog and app details"
    },
    "terms_of_service_url": {
      "type": "string",
      "description": "Terms of Service URL for login dialog and app details"
    },
    "data_deletion_url": {
      "type": "string",
      "description": "URL for user data deletion instructions"
    },
    "app_icon_url": {
      "type": "string",
      "description": "App icon URL (1024 x 1024)"
    }
  },
  "required": []
}