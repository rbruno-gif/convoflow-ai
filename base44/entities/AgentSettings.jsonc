{
  "name": "AgentSettings",
  "type": "object",
  "properties": {
    "brand_id": {
      "type": "string",
      "description": "Brand this settings belongs to"
    },
    "campaign_id": {
      "type": "string",
      "description": "Campaign this settings belongs to"
    },
    "store_name": {
      "type": "string"
    },
    "ai_persona_name": {
      "type": "string",
      "default": "ShopBot"
    },
    "welcome_message": {
      "type": "string"
    },
    "ai_instructions": {
      "type": "string",
      "description": "Custom instructions for the AI agent"
    },
    "auto_flag_keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "handoff_message": {
      "type": "string"
    },
    "business_hours": {
      "type": "string"
    },
    "is_ai_active": {
      "type": "boolean",
      "default": true
    },
    "assigned_brands": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Brand slugs this agent is assigned to"
    },
    "can_see_all_brands": {
      "type": "boolean",
      "default": false,
      "description": "Whether this agent can see all brands"
    }
  },
  "required": [
    "store_name"
  ]
}