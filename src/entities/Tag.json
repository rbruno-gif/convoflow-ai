{
  "name": "Tag",
  "type": "object",
  "properties": {
    "brand_id": {
      "type": "string",
      "description": "Brand this tag belongs to"
    },
    "name": {
      "type": "string",
      "description": "Tag name"
    },
    "color": {
      "type": "string",
      "description": "Hex color code"
    },
    "description": {
      "type": "string"
    },
    "created_by": {
      "type": "string",
      "description": "Agent email who created"
    },
    "usage_count": {
      "type": "number",
      "default": 0
    },
    "is_archived": {
      "type": "boolean",
      "default": false,
      "description": "Archived tags not assignable"
    }
  },
  "required": ["brand_id", "name", "color"]
}