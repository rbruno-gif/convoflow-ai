{
  "name": "AgenticAction",
  "type": "object",
  "properties": {
    "brand_id": {
      "type": "string"
    },
    "ai_agent_id": {
      "type": "string"
    },
    "conversation_id": {
      "type": "string"
    },
    "customer_id": {
      "type": "string"
    },
    "step": {
      "type": "string",
      "enum": [
        "understand",
        "plan",
        "execute",
        "approval",
        "verify",
        "respond",
        "log"
      ],
      "default": "understand"
    },
    "tool_used": {
      "type": "string"
    },
    "input_data": {
      "type": "object",
      "description": "JSON input to the tool"
    },
    "output_data": {
      "type": "object",
      "description": "JSON output from the tool"
    },
    "reasoning": {
      "type": "string",
      "description": "Why the AI chose this action"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "approved",
        "rejected",
        "executed",
        "failed"
      ],
      "default": "proposed"
    },
    "approved_by": {
      "type": "string",
      "description": "Agent ID who approved"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "error_message": {
      "type": "string"
    }
  },
  "required": [
    "brand_id",
    "ai_agent_id",
    "conversation_id",
    "step"
  ]
}