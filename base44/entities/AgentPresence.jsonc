{
  "name": "AgentPresence",
  "type": "object",
  "properties": {
    "agent_email": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "online",
        "away",
        "dnd",
        "offline"
      ],
      "default": "offline"
    },
    "last_seen": {
      "type": "string",
      "format": "date-time"
    },
    "muted_channels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "agent_email"
  ]
}