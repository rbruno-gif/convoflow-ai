{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "agent",
        "supervisor"
      ],
      "default": "agent",
      "description": "User role in the system"
    },
    "assigned_brands": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Brand IDs this user is assigned to"
    }
  }
}