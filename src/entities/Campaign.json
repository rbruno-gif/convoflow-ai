{
  "name": "Campaign",
  "type": "object",
  "properties": {
    "brand_id": {
      "type": "string",
      "description": "Brand this campaign belongs to"
    },
    "name": {
      "type": "string"
    },
    "channel": {
      "type": "string",
      "enum": ["chat", "email", "whatsapp", "sms"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "scheduled", "running", "completed", "cancelled"],
      "default": "draft"
    },
    "audience_filter": {
      "type": "object",
      "description": "JSON filter criteria"
    },
    "message_content": {
      "type": "string",
      "description": "Message body/text"
    },
    "subject": {
      "type": "string",
      "description": "Email subject only"
    },
    "scheduled_at": {
      "type": "string",
      "format": "date-time"
    },
    "sent_count": {
      "type": "number",
      "default": 0
    },
    "delivered_count": {
      "type": "number",
      "default": 0
    },
    "opened_count": {
      "type": "number",
      "default": 0
    },
    "replied_count": {
      "type": "number",
      "default": 0
    },
    "opt_out_count": {
      "type": "number",
      "default": 0
    },
    "created_by": {
      "type": "string"
    }
  },
  "required": ["brand_id", "name", "channel", "message_content"]
}