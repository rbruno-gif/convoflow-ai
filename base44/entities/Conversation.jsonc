{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "brand_id": {
      "type": "string",
      "description": "Brand this conversation belongs to"
    },
    "department_id": {
      "type": "string",
      "description": "Department this conversation is routed to"
    },
    "customer_name": {
      "type": "string",
      "description": "Customer name"
    },
    "customer_email": {
      "type": "string",
      "description": "Customer email"
    },
    "customer_phone": {
      "type": "string",
      "description": "Customer phone"
    },
    "customer_avatar": {
      "type": "string",
      "description": "Customer avatar URL"
    },
    "channel": {
      "type": "string",
      "enum": [
        "chat",
        "email",
        "whatsapp",
        "sms",
        "facebook",
        "voice"
      ],
      "default": "chat",
      "description": "Communication channel"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "waiting",
        "flagged",
        "resolved",
        "human_requested"
      ],
      "default": "active"
    },
    "mode": {
      "type": "string",
      "enum": [
        "ai",
        "human"
      ],
      "default": "ai",
      "description": "Whether AI or human is handling"
    },
    "assigned_agent": {
      "type": "string",
      "description": "Agent email assigned to this conversation"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_time": {
      "type": "string",
      "format": "date-time"
    },
    "unread_count": {
      "type": "number",
      "default": 0
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high",
        "urgent"
      ],
      "default": "normal"
    },
    "sentiment": {
      "type": "string",
      "enum": [
        "positive",
        "neutral",
        "negative"
      ],
      "default": "neutral"
    },
    "is_urgent": {
      "type": "boolean",
      "default": false
    },
    "intent": {
      "type": "string",
      "enum": [
        "sales",
        "support",
        "billing",
        "complaint",
        "feedback",
        "other"
      ],
      "default": "other"
    },
    "conversation_summary": {
      "type": "string",
      "description": "AI-generated summary"
    },
    "key_topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resolution_status": {
      "type": "string",
      "enum": [
        "unresolved",
        "resolved",
        "escalated"
      ],
      "default": "unresolved"
    },
    "transfer_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from_agent": {
            "type": "string"
          },
          "to_agent": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "wait_time_seconds": {
      "type": "number",
      "default": 0
    },
    "queue_position": {
      "type": "number",
      "description": "Position in queue if waiting"
    }
  },
  "required": [
    "brand_id",
    "department_id",
    "customer_name"
  ]
}