{
  "name": "Channel",
  "type": "object",
  "properties": {
    "brand_id": {
      "type": "string",
      "description": "Brand this channel belongs to"
    },
    "name": {
      "type": "string",
      "description": "Channel name (e.g., general, support)"
    },
    "type": {
      "type": "string",
      "enum": ["public", "private"],
      "default": "public"
    },
    "description": {
      "type": "string"
    },
    "is_default": {
      "type": "boolean",
      "default": false,
      "description": "Auto-created default channels"
    },
    "manager_post_only": {
      "type": "boolean",
      "default": false,
      "description": "Only managers can post (agents can read/react)"
    },
    "members": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Agent emails in this channel (for private channels)"
    },
    "unread_count_by_user": {
      "type": "object",
      "description": "Unread message count per agent email"
    },
    "created_by": {
      "type": "string"
    }
  },
  "required": ["brand_id", "name", "type"]
}