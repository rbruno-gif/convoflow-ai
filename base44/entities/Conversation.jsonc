{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "brand_id": {
      "type": "string",
      "description": "Brand this conversation belongs to"
    },
    "department_id": {
      "type": "string",
      "description": "Department this conversation is assigned to"
    },
    "customer_id": {
      "type": "string",
      "description": "Reference to CustomerProfile entity"
    },
    "channel": {
      "type": "string",
      "enum": [
        "chat",
        "email",
        "whatsapp",
        "sms",
        "voice",
        "messenger"
      ],
      "default": "chat",
      "description": "Communication channel"
    },
    "channel_id": {
      "type": "string",
      "description": "External ID for channel-specific conversations (e.g., sender_id for messenger)"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "pending",
        "resolved",
        "archived"
      ],
      "default": "open"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high",
        "urgent"
      ],
      "default": "normal"
    },
    "assigned_agent_id": {
      "type": "string",
      "description": "Agent ID (null = unassigned)"
    },
    "queue_position": {
      "type": "number",
      "description": "Position in queue (null if not in queue)"
    },
    "priority_lane": {
      "type": "string",
      "enum": [
        "vip",
        "standard",
        "low"
      ],
      "default": "standard"
    },
    "wait_time_seconds": {
      "type": "number",
      "default": 0
    },
    "first_response_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time"
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time"
    },
    "sla_first_response_due_at": {
      "type": "string",
      "format": "date-time"
    },
    "sla_resolution_due_at": {
      "type": "string",
      "format": "date-time"
    },
    "sla_first_response_breached": {
      "type": "boolean",
      "default": false
    },
    "sla_resolution_breached": {
      "type": "boolean",
      "default": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "internal_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "customer_name": {
      "type": "string"
    },
    "customer_email": {
      "type": "string"
    },
    "customer_avatar": {
      "type": "string"
    },
    "unread_count": {
      "type": "number",
      "default": 0
    },
    "transfer_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from_agent_id": {
            "type": "string"
          },
          "to_agent_id": {
            "type": "string"
          },
          "to_department_id": {
            "type": "string"
          },
          "handover_note": {
            "type": "string"
          },
          "transferred_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "required": [
    "brand_id",
    "department_id",
    "customer_id",
    "channel",
    "customer_name"
  ]
}