{
  "name": "PriorityAutoRule",
  "type": "object",
  "properties": {
    "brand_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "rule_order": {
      "type": "number",
      "description": "Execution order"
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": {"type": "string"},
          "operator": {"type": "string"},
          "value": {}
        }
      },
      "description": "Conditions to match"
    },
    "set_priority": {
      "type": "string",
      "enum": ["low", "normal", "high", "urgent"]
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "created_by": {
      "type": "string"
    }
  },
  "required": ["brand_id", "name", "conditions", "set_priority"]
}