{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "brand_id": {
      "type": "string",
      "description": "Brand this conversation belongs to"
    },
    "customer_name": {
      "type": "string",
      "description": "Customer's name"
    },
    "customer_fb_id": {
      "type": "string",
      "description": "External user ID (Facebook, Umnico contact ID, etc.)"
    },
    "customer_avatar": {
      "type": "string",
      "description": "Customer avatar URL"
    },
    "campaign_id": {
      "type": "string",
      "description": "Campaign this conversation belongs to"
    },
    "channel": {
      "type": "string",
      "description": "Channel of the conversation (e.g., umnico, facebook, whatsapp)"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "waiting",
        "flagged",
        "resolved",
        "human_requested",
        "ai_handling",
        "human_handling"
      ],
      "default": "active"
    },
    "mode": {
      "type": "string",
      "enum": [
        "ai",
        "human"
      ],
      "default": "ai",
      "description": "Whether AI or human is handling"
    },
    "assigned_agent": {
      "type": "string",
      "description": "Agent email assigned to this convo"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_time": {
      "type": "string",
      "format": "date-time"
    },
    "unread_count": {
      "type": "number",
      "default": 0
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "order_intent": {
      "type": "boolean",
      "default": false,
      "description": "AI detected order intent"
    },
    "flagged_reason": {
      "type": "string"
    },
    "sentiment": {
      "type": "string",
      "enum": [
        "positive",
        "neutral",
        "negative"
      ],
      "default": "neutral"
    },
    "is_urgent": {
      "type": "boolean",
      "default": false
    },
    "sentiment_updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "intent": {
      "type": "string",
      "enum": [
        "order_inquiry",
        "product_support",
        "billing_issue",
        "complaint",
        "feedback",
        "general_question",
        "returns_refunds",
        "shipping",
        "technical_support",
        "other"
      ],
      "default": "general_question"
    },
    "conversation_summary": {
      "type": "string"
    },
    "key_topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resolution_status": {
      "type": "string",
      "enum": [
        "unresolved",
        "resolved",
        "escalated"
      ],
      "default": "unresolved"
    },
    "ai_resolution_attempted": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "customer_name"
  ]
}