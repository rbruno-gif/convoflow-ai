{
  "name": "APIKey",
  "type": "object",
  "properties": {
    "brand_id": {
      "type": "string"
    },
    "key_name": {
      "type": "string"
    },
    "key_hash": {
      "type": "string",
      "description": "Hashed key (not shown after creation)"
    },
    "key_preview": {
      "type": "string",
      "description": "Last 4 characters only"
    },
    "scope": {
      "type": "string",
      "enum": ["read", "read_write", "admin"],
      "default": "read"
    },
    "status": {
      "type": "string",
      "enum": ["active", "revoked"],
      "default": "active"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_used_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string"
    }
  },
  "required": ["brand_id", "key_name", "key_hash"]
}