{
  "name": "ScheduledReport",
  "type": "object",
  "properties": {
    "brand_id": {
      "type": "string"
    },
    "report_name": {
      "type": "string"
    },
    "schedule_type": {
      "type": "string",
      "enum": ["weekly", "monthly"],
      "default": "weekly"
    },
    "schedule_day": {
      "type": "string",
      "description": "Day of week (Mon) or day of month (1-28)"
    },
    "schedule_time": {
      "type": "string",
      "description": "HH:MM format"
    },
    "metric_categories": {
      "type": "array",
      "items": {"type": "string"},
      "description": "e.g. [conversations, tickets, csat, ai]"
    },
    "recipient_emails": {
      "type": "array",
      "items": {"type": "string"}
    },
    "format": {
      "type": "string",
      "enum": ["pdf", "csv"],
      "default": "pdf"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "last_sent_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string"
    }
  },
  "required": ["brand_id", "report_name", "schedule_type", "recipient_emails"]
}