{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "customer_name": {
      "type": "string",
      "description": "Customer's name from Facebook"
    },
    "customer_fb_id": {
      "type": "string",
      "description": "Facebook user ID"
    },
    "customer_avatar": {
      "type": "string",
      "description": "Customer avatar URL"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "waiting",
        "flagged",
        "resolved",
        "human_requested"
      ],
      "default": "active"
    },
    "mode": {
      "type": "string",
      "enum": [
        "ai",
        "human"
      ],
      "default": "ai",
      "description": "Whether AI or human is handling"
    },
    "assigned_agent": {
      "type": "string",
      "description": "Agent email assigned to this convo"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_time": {
      "type": "string",
      "format": "date-time"
    },
    "unread_count": {
      "type": "number",
      "default": 0
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "order_intent": {
      "type": "boolean",
      "default": false,
      "description": "AI detected order intent"
    },
    "flagged_reason": {
      "type": "string"
    },
    "sentiment": {
      "type": "string",
      "enum": [
        "positive",
        "neutral",
        "negative"
      ],
      "default": "neutral",
      "description": "Detected sentiment from latest messages"
    },
    "is_urgent": {
      "type": "boolean",
      "default": false,
      "description": "Auto-flagged as urgent (negative sentiment + keywords)"
    },
    "sentiment_updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "When sentiment was last analyzed"
    },
    "intent": {
      "type": "string",
      "enum": [
        "order_inquiry",
        "product_support",
        "billing_issue",
        "complaint",
        "feedback",
        "general_question",
        "returns_refunds",
        "shipping",
        "technical_support",
        "other"
      ],
      "default": "general_question",
      "description": "Detected conversation intent"
    },
    "conversation_summary": {
      "type": "string",
      "description": "AI-generated summary of conversation"
    },
    "key_topics": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Key topics/keywords extracted from conversation"
    },
    "resolution_status": {
      "type": "string",
      "enum": [
        "unresolved",
        "resolved",
        "escalated"
      ],
      "default": "unresolved"
    },
    "ai_resolution_attempted": {
      "type": "boolean",
      "default": false,
      "description": "AI attempted to resolve before handoff"
    }
  },
  "required": [
    "customer_name"
  ]
}